#!/bin/sh

PATH="${ZN_M2_PATH:-/usr/sbin:/usr/bin:/sbin:/bin}"

TAG="zn-m2-healthcheck"
STATE_DIR="${STATE_DIR:-/tmp/zn-m2-healthcheck}"
STATE_OWNER="${STATE_OWNER:-root:root}"
INIT_DIR="${INIT_DIR:-/etc/init.d}"
MIN_MEM_KB="${MIN_MEM_KB:-32768}"
COOLDOWN_SEC="${COOLDOWN_SEC:-600}"

umask 077
if [ -L "$STATE_DIR" ] || { [ -e "$STATE_DIR" ] && [ ! -d "$STATE_DIR" ]; }; then
	rm -rf "$STATE_DIR"
fi
mkdir -p "$STATE_DIR" || exit 1
chown "$STATE_OWNER" "$STATE_DIR" 2>/dev/null || exit 1
chmod 0700 "$STATE_DIR" || exit 1

log() {
	logger -t "$TAG" "$*"
	[ -t 1 ] && printf '%s\n' "$*"
}

cooldown_elapsed() {
	name="$1"
	now="$(date +%s 2>/dev/null || echo 0)"
	file="${STATE_DIR}/${name}.last"
	if [ -L "$file" ] || { [ -e "$file" ] && [ ! -f "$file" ]; }; then
		rm -f "$file"
	fi
	last="$(cat "$file" 2>/dev/null || echo 0)"
	case "$last" in
		''|*[!0-9]*) last=0 ;;
	esac

	if [ "$now" -eq 0 ] || [ $((now - last)) -ge "$COOLDOWN_SEC" ]; then
		tmp="${file}.tmp.$$"
		printf '%s\n' "$now" > "$tmp" || return 1
		mv -f "$tmp" "$file" || {
			rm -f "$tmp"
			return 1
		}
		return 0
	fi

	return 1
}

restart_service() {
	service="$1"

	if [ -x "${INIT_DIR}/${service}" ] && cooldown_elapsed "$service"; then
		log "restart ${service}"
		"${INIT_DIR}/${service}" restart >/dev/null 2>&1 || log "restart ${service} failed"
	fi
}

has_default_route() {
	ip route show default 2>/dev/null | grep -q .
}

check_memory() {
	mem_available="$(awk '/MemAvailable/ {print $2; exit}' /proc/meminfo 2>/dev/null)"

	if [ -n "$mem_available" ] && [ "$mem_available" -lt "$MIN_MEM_KB" ]; then
		log "low memory: ${mem_available}KB available"
	fi
}

check_dns() {
	local_domain="$(uci -q get dhcp.@dnsmasq[0].domain 2>/dev/null || echo lan)"
	hostname="$(uci -q get system.@system[0].hostname 2>/dev/null || hostname 2>/dev/null || echo OpenWrt)"
	local_ok=0
	remote_failed=0

	for host in "${hostname}.${local_domain}" localhost; do
		if ! nslookup "$host" 127.0.0.1 >/dev/null 2>&1; then
			log "local dns lookup failed: ${host}"
		else
			local_ok=1
		fi
	done

	if [ "$local_ok" -eq 0 ]; then
		restart_service dnsmasq
		return
	fi

	for host in www.baidu.com openwrt.org; do
		if ! nslookup "$host" 127.0.0.1 >/dev/null 2>&1; then
			log "remote dns lookup warning: ${host}"
			remote_failed=1
		fi
	done

	[ "$remote_failed" -eq 0 ] || return 0
}

check_proxy() {
	if [ ! -x "${INIT_DIR}/homeproxy" ] ||
	   ! "${INIT_DIR}/homeproxy" enabled >/dev/null 2>&1; then
		return 0
	fi

	routing_mode="$(uci -q get homeproxy.config.routing_mode 2>/dev/null || echo bypass_mainland_china)"
	if [ "$routing_mode" = "custom" ]; then
		outbound_node="$(uci -q get homeproxy.routing.default_outbound 2>/dev/null || echo nil)"
	else
		outbound_node="$(uci -q get homeproxy.config.main_node 2>/dev/null || echo nil)"
	fi
	server_enabled="$(uci -q get homeproxy.server.enabled 2>/dev/null || echo 0)"
	if [ -z "$outbound_node" ] || [ "$outbound_node" = "nil" ]; then
		[ "$server_enabled" = "1" ] || return 0
	fi

	if ! pidof sing-box >/dev/null 2>&1; then
		log "homeproxy is enabled but sing-box is not running"
		restart_service homeproxy
	fi
}

check_memory

if has_default_route; then
	check_dns
	check_proxy
fi

exit 0
