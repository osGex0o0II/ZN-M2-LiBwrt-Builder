# ZN-M2 256M / IPQ60xx / LiBwrt 6.12 NSS / wired-only Main Router build
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_zn_m2=y

# Build only this device profile.
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_DEVEL=y
CONFIG_CCACHE=y
# Only factory and sysupgrade images are published or used by this builder.
# Qualcommax otherwise defaults to building an extra embedded initramfs image.
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# IPQ base profile for 256 MB physical RAM. LiBwrt still includes the board's
# 512M DTS fragment, so libwrt.sh separately removes the unused 55 MiB WCSS Q6
# carveout for this permanently wired-only variant; NSS keeps its 16 MiB region.
CONFIG_IPQ_MEM_PROFILE_256=y
# CONFIG_IPQ_MEM_PROFILE_512 is not set
# CONFIG_IPQ_MEM_PROFILE_1024 is not set

# NSS has a separate memory profile; ipq60xx otherwise defaults to 512 MB.
CONFIG_NSS_MEM_PROFILE_LOW=y
# CONFIG_NSS_MEM_PROFILE_MEDIUM is not set
# CONFIG_NSS_MEM_PROFILE_HIGH is not set

# Kernel config export (/proc/config.gz) for runtime debugging.
CONFIG_KERNEL_IKCONFIG=y
CONFIG_KERNEL_IKCONFIG_PROC=y

# Wireless stack removed for the wired-only ZN-M2 build.
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n
CONFIG_PACKAGE_kmod-ath10k=n
CONFIG_PACKAGE_kmod-ath10k-ct=n
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n

# NSS hardware acceleration.
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_NSS_DRV_BRIDGE_ENABLE=y
CONFIG_NSS_DRV_CRYPTO_ENABLE=n
CONFIG_NSS_DRV_GRE_ENABLE=n
CONFIG_NSS_DRV_GRE_REDIR_ENABLE=n
CONFIG_NSS_DRV_GRE_TUNNEL_ENABLE=n
CONFIG_NSS_DRV_IGS_ENABLE=y
CONFIG_NSS_DRV_IPV6_ENABLE=y
CONFIG_NSS_DRV_L2TP_ENABLE=n
CONFIG_NSS_DRV_LAG_ENABLE=y
CONFIG_NSS_DRV_MAPT_ENABLE=n
CONFIG_NSS_DRV_PPPOE_ENABLE=y
CONFIG_NSS_DRV_PPTP_ENABLE=n
CONFIG_NSS_DRV_VIRT_IF_ENABLE=y
CONFIG_NSS_DRV_VLAN_ENABLE=y
# IPSEC 强制禁用 — 内核 6.12 已移除 vzalloc，qca-nss-drv IPSEC 编译失败。
# 参考：LiBwrt/openwrt-6.x#96
CONFIG_NSS_DRV_IPSEC_ENABLE=n
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_FIRMWARE_VERSION_12_2=y
CONFIG_PACKAGE_kmod-qca-mcs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y

# LuCI UI, terminal, and basic diagnostics.
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_DEFAULT_luci-theme-aurora=y
CONFIG_LUCI_THEME="luci-theme-aurora"
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_ip-full=y

# BBR, firewall, and routing helpers.
CONFIG_PACKAGE_kmod-tcp-bbr=y

# fq qdisc 支持 — BBR 运行必需。
CONFIG_PACKAGE_kmod-sched-core=y

# ZRAM swap - safety net for low-RAM devices. The upstream init script sizes
# the device from the final kernel-visible RAM, so do not encode the old WCSS
# carveout layout as a fixed capacity here.
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-bonding=y
CONFIG_PACKAGE_kmod-dsa=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-arp=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-connlimit=y
CONFIG_PACKAGE_kmod-nft-dup-inet=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_kmod-wireguard=n

# Benchmark — 4-thread CoreMark. Runs once at first boot and caches the score.
CONFIG_PACKAGE_coremark=y
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=4

# Main Router add-ons.
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y

# Explicitly excluded.
CONFIG_PACKAGE_ipq-wifi-zn_m2=n
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_miniupnpd-nftables=y
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_kmod-qca-nss-drv-eogremgr=n
CONFIG_PACKAGE_kmod-qca-nss-drv-gre=n
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=n
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=n
CONFIG_PACKAGE_kmod-qca-nss-drv-match=n
CONFIG_PACKAGE_kmod-qca-nss-drv-mirror=n
CONFIG_PACKAGE_kmod-qca-nss-drv-netlink=n
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=n
CONFIG_PACKAGE_kmod-qca-nss-drv-tun6rd=n
CONFIG_PACKAGE_kmod-qca-nss-drv-tunipip6=n
CONFIG_PACKAGE_kmod-qca-nss-drv-vxlanmgr=n
CONFIG_PACKAGE_kmod-qca-nss-drv-wifi-meshmgr=n
CONFIG_PACKAGE_kmod-qca-nss-crypto=n
CONFIG_PACKAGE_nss-eip-firmware=n
# Keep WAN PPPoE while excluding unused generic tunnel protocols and LiBwrt's
# syncdial/MPPE extras. The 256M feed patches remove the dependencies that
# would otherwise select these packages.
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_shellsync=n
CONFIG_PACKAGE_kmod-macvlan=n
CONFIG_PACKAGE_kmod-mppe=n
CONFIG_PACKAGE_kmod-pptp=n
CONFIG_PACKAGE_kmod-pppol2tp=n
CONFIG_PACKAGE_kmod-l2tp=n
CONFIG_PACKAGE_kmod-l2tp-eth=n
CONFIG_PACKAGE_kmod-l2tp-ip=n
CONFIG_PACKAGE_kmod-gre=n
CONFIG_PACKAGE_kmod-gre6=n
CONFIG_PACKAGE_e2fsprogs=n
CONFIG_PACKAGE_f2fs-tools=n
CONFIG_PACKAGE_f2fsck=n
CONFIG_PACKAGE_mkf2fs=n
CONFIG_PACKAGE_losetup=n
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-fs-f2fs=n
CONFIG_PACKAGE_kmod-leds-pwm=n
CONFIG_PACKAGE_kmod-phy-aquantia=n
CONFIG_PACKAGE_kmod-usb-common=n
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb-dwc3=n
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=n
CONFIG_PACKAGE_kmod-usb-roles=n
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_PACKAGE_kmod-usb-storage-extras=n
CONFIG_PACKAGE_kmod-usb-storage-uas=n
CONFIG_PACKAGE_kmod-usb-xhci-hcd=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_block-mount=n
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n
